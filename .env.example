# StreamVault Environment Variables

# ==========================================
# Backend Configuration (StreamVault.Api)
# ==========================================

# Database Connection
# Development uses SQLite with relative path
# Production should use absolute path or connection string
DB_CONNECTION_STRING=Data Source=streamvault.db

# JWT Configuration (REQUIRED for production)
# Generate a secure 256+ bit key for production
# Example: openssl rand -base64 32
JWT_KEY=CHANGE_ME_PRODUCTION_256bit_minimum_key_value_use_user_secrets_or_env_vars
JWT_ISSUER=StreamVault
JWT_AUDIENCE=StreamVault.Client
JWT_EXPIRES_MINUTES=120

# External API Keys
# Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# YouTube API Key
# Get from https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# ==========================================
# Frontend Configuration
# ==========================================

# API proxy target for development
# Vite proxy redirects /api/* to this target
VITE_API_PROXY_TARGET=http://localhost:7166

# Backend API endpoint (production)
# Used by frontend when served from production build
VITE_API_BASE_URL=http://localhost:7166

# ==========================================
# Backend Server
# ==========================================

# ASPNETCORE_ENVIRONMENT
# Options: Development, Production, Staging
ASPNETCORE_ENVIRONMENT=Development

# ASPNETCORE_URLS - Server binding
ASPNETCORE_URLS=http://localhost:7166

# ==========================================
# Notes
# ==========================================

# For development:
# 1. Copy this file to .env or .env.local
# 2. Fill in API keys from their respective platforms
# 3. Backend reads from appsettings.Development.json which overrides these values
# 4. Frontend reads VITE_* variables at build time

# For production:
# 1. Use .NET User Secrets or environment variables for sensitive data
# 2. Set ASPNETCORE_ENVIRONMENT=Production
# 3. Ensure JWT_KEY is strong and unique
# 4. Use absolute database path or proper connection string
# 5. Configure CORS in appsettings.Production.json
